# Copy this file to deploy/.env on the server.

# Required secret for backend token signing.
JWT_SECRET=change-me

# Recommended production settings.
BASALTPASS_ENV=production
BASALTPASS_SERVER_ADDRESS=:8101

# Adjust these to your actual domains.
BASALTPASS_CORS_ALLOW_ORIGINS=https://auth.example.com,https://admin.example.com

# Email configuration.
# BASALTPASS_EMAIL_PROVIDER=smtp
# BASALTPASS_EMAIL_FROM=no-reply@example.com
#
# SMTP:
# BASALTPASS_EMAIL_SMTP_HOST=smtp.example.com
# BASALTPASS_EMAIL_SMTP_PORT=587
# BASALTPASS_EMAIL_SMTP_USERNAME=mailer@example.com
# BASALTPASS_EMAIL_SMTP_PASSWORD=change-me
# BASALTPASS_EMAIL_SMTP_USE_TLS=true
# BASALTPASS_EMAIL_SMTP_USE_SSL=false
# BASALTPASS_EMAIL_SMTP_SKIP_CERT_VERIFY=false
#
# AWS SES:
# BASALTPASS_EMAIL_PROVIDER=aws_ses
# BASALTPASS_EMAIL_AWS_SES_REGION=us-east-1
# BASALTPASS_EMAIL_AWS_SES_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
# BASALTPASS_EMAIL_AWS_SES_SECRET_ACCESS_KEY=change-me
# BASALTPASS_EMAIL_AWS_SES_CONFIGURATION_SET=

# Optional bootstrap admin.
# BASALTPASS_ADMIN_EMAIL=admin@example.com
# BASALTPASS_ADMIN_PASSWORD=ChangeMe123!
