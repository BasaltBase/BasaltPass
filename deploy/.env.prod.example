# Copy this file to deploy/.env on the server.

# Required secret for backend token signing.
JWT_SECRET=change-me

# Recommended production settings.
BASALTPASS_ENV=production
BASALTPASS_SERVER_ADDRESS=:8101

# Adjust these to your actual domains.
BASALTPASS_CORS_ALLOW_ORIGINS=https://auth.example.com,https://admin.example.com

# Optional bootstrap admin.
# BASALTPASS_ADMIN_EMAIL=admin@example.com
# BASALTPASS_ADMIN_PASSWORD=ChangeMe123!
